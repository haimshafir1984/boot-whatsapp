WHATSAPP_PROVIDER=TWILIO_API

# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Use either TWILIO_FROM or TWILIO_MESSAGING_SERVICE_SID.
# Sandbox example: whatsapp:+14155238886
TWILIO_FROM=whatsapp:+14155238886
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Add this token to the webhook URL as ?token=...
TWILIO_WEBHOOK_TOKEN=change-me-local-token

# Optional: needed only when sending uploaded files/media through Twilio.
# Example with ngrok:
# TWILIO_MEDIA_BASE_URL=https://your-ngrok-domain.ngrok-free.app/twilio-media
TWILIO_MEDIA_BASE_URL=

# Local app settings
CLIENT_ACCESS_TOKEN=local-client-password
STORAGE_PATH=./data/twilio-local/contacts.json
UPLOADS_PATH=./data/twilio-local/uploads
GOOGLE_TOKEN_PATH=./data/twilio-local/google-token.json
OWNER_STORAGE_PATH=./data/twilio-local/owner/clients.json
PORT=3001
