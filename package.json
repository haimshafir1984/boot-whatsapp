{
  "name": "whatsapp-status-bot",
  "version": "1.0.0",
  "description": "Personal WhatsApp automation bot - saves contacts and sends vCard reply",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "measure:whatsapp-memory": "node scripts/measure-whatsapp-memory.js",
    "test:flow-recovery": "npm run build && node scripts/test-flow-recovery.js",
    "test:flow-concurrency": "npm run build && node scripts/test-flow-concurrency.js",
    "db:migrate": "node scripts/migrate-json-to-postgres.js",
    "db:migrate:apply": "node scripts/migrate-json-to-postgres.js --apply"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "googleapis": "^140.0.0",
    "open": "^8.4.2",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}



